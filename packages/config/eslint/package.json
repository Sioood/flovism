{
  "name": "@flovism/eslint",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "eslint.config.js",
    "src/**/*.ts"
  ],
  "type": "module",
  "scripts": {
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "lint:oxlint": "pnpx oxlint || true",
    "lint:eslint": "pnpm exec eslint . --ext .ts,.js",
    "format": "pnpx prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@flovism/oxlint": "workspace:^",
    "@flovism/prettier": "workspace:^",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "eslint": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsonc": "^3.1.1",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-tailwindcss": "beta",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-yml": "^3.3.1",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^3.1.0",
    "oxlint": "catalog:",
    "typescript-eslint": "^8.56.1",
    "yaml-eslint-parser": "^2.0.0"
  },
  "lint-staged": {
    "**/*.{json,js,ts,md,yaml,yml}": [
      "oxlint --fix",
      "eslint --fix",
      "prettier --write"
    ]
  }
}
