{
  "name": "@flovism/ui",
  "type": "module",
  "version": "0.0.1",
  "main": "./nuxt.config.ts",
  "scripts": {
    "dev": "nuxi dev .playground",
    "prepare": "nuxt prepare .playground",
    "build": "nuxt build .playground",
    "generate": "nuxt generate .playground",
    "preview": "nuxt preview .playground",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "lint:oxlint": "pnpx oxlint || true",
    "lint:eslint": "pnpm exec eslint .",
    "i18n:coverage": "node ./node_modules/@flovism/nuxt-essentials/i18n/utils/coverage.ts -f ./i18n/locales"
  },
  "dependencies": {
    "@flovism/nuxt-essentials": "workspace:^",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@flovism/eslint": "workspace:^",
    "@flovism/oxlint": "workspace:^",
    "@flovism/prettier": "workspace:^",
    "@nuxt/fonts": "0.11.4",
    "@nuxt/icon": "1.15.0",
    "@nuxt/image": "1.10.0",
    "@nuxt/kit": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "nuxt": "catalog:",
    "typescript": "catalog:",
    "v-gsap-nuxt": "^1.5.12",
    "vue": "catalog:"
  },
  "lint-staged": {
    "**/*.{json,js,ts,md,yaml,yml,vue}": [
      "oxlint --fix",
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prettier": "@flovism/prettier"
}
