meta {
  name: auth signup
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/signup
  body: formUrlEncoded
  auth: none
}

headers {
  content-type: application/json
}

body:form-urlencoded {
  email: {{auth.defaultUserEmail}}
  password: {{auth.defaultUserPassword}}
  passwordConfirmation: {{auth.defaultUserPassword}}
  fullName: {{auth.defaultUserFullName}}
}
